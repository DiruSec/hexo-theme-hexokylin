<% if (post.categories && post.categories.length){ %>
    <div class="article-info">
        <% if (post.categories && post.categories.length){ %>
        文章位于分类「
        <% for (var i in post.categories.data) { %>
            <% var category = post.categories.data[i].name %>
            <a href="<%- url_for('/categories/'+category) %> "><code><%= category  %></code></a>
        <% } %>
        」下，
        <% } %>
        <% if (post.tags && post.tags.length){ %>
        包含「
        <% for (var i in post.tags.data) { %>
            <% var tag = post.tags.data[i].name %>
            <a href="<%- url_for('/tags/'+tag) %> "><code><%= tag %></code></a>
        <% } %>
        」标签
        <% } %>
        。
        </p>
    </div>
  <% } %>